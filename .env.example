# PepTalk Environment Variables
# Copy this file to .env and fill in your values.

# X.AI / Grok API key for the PepTalk AI assistant
# Get one at https://console.x.ai/
EXPO_PUBLIC_XAI_API_KEY=

# Analytics endpoint URL (optional — events silently skip if empty)
EXPO_PUBLIC_ANALYTICS_URL=

# USDA FoodData Central API key (free — https://fdc.nal.usda.gov/api-key-signup)
EXPO_PUBLIC_USDA_API_KEY=

# Spoonacular API key (free 150 req/day — https://spoonacular.com/food-api) — used for food images only
EXPO_PUBLIC_SPOONACULAR_API_KEY=
